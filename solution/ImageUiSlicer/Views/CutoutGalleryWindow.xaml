<Window x:Class="ImageUiSlicer.Views.CutoutGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cutout Gallery"
        Width="1040"
        Height="720"
        MinWidth="760"
        MinHeight="520"
        Background="#0B1116"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/Icons/ImageUiSlicer_Icon.ico">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                CornerRadius="20"
                Background="#12202A"
                BorderBrush="#243843"
                BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Cutout Gallery"
                               Foreground="#F1F6F8"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock x:Name="GalleryCountText"
                               Margin="0,4,0,0"
                               Foreground="#97AAB3"
                               Text="0 cutouts" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#97AAB3"
                           Text="Fresh previews from your current project." />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Border x:Name="EmptyStatePanel"
                    Padding="24"
                    CornerRadius="20"
                    Background="#10181E"
                    BorderBrush="#243843"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No cutouts yet"
                               Foreground="#F1F6F8"
                               FontSize="28"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#97AAB3"
                               FontSize="16"
                               TextAlignment="Center"
                               Text="Draw a lasso or polygon selection, commit it, then open this gallery again to preview every cutout in one place." />
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="GalleryScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <ItemsControl x:Name="GalleryItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="270"
                                    Margin="0,0,16,16"
                                    Padding="14"
                                    CornerRadius="18"
                                    Background="#111D24"
                                    BorderBrush="#243843"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Border Height="200"
                                            Padding="12"
                                            CornerRadius="14"
                                            Background="#0B1116"
                                            BorderBrush="#20303A"
                                            BorderThickness="1">
                                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                                            <Image Source="{Binding PreviewImage}" />
                                        </Viewbox>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding Name}"
                                               Foreground="#F1F6F8"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding SizeLabel}"
                                                   Foreground="#97AAB3" />
                                        <Border DockPanel.Dock="Right"
                                                Background="#243840"
                                                CornerRadius="10"
                                                Padding="8,3">
                                            <TextBlock Text="{Binding Mode}"
                                                       Foreground="#B9D8DF"
                                                       FontSize="11" />
                                        </Border>
                                    </DockPanel>
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ConfidenceLabel}"
                                               Foreground="#B9D8DF"
                                               FontSize="11" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>


